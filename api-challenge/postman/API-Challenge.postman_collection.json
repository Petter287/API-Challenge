    {
      "name": "14 - Casos 1 y 3: materia aprobada y recálculo",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students/{{studentId}}/subjects-status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "students",
            "{{studentId}}",
            "subjects-status"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Consulta recalculada - HTTP 200', () => pm.response.to.have.status(200));",
              "const materias = pm.response.json();",
              "const runId = pm.collectionVariables.get('runId');",
              "const historia = materias.find(item => item.materia.includes(`Historia ${runId}`));",
              "const geografia = materias.find(item => item.materia.includes(`Geografía ${runId}`));",
              "",
              "pm.test('Historia fue recalculada como aprobada', () => pm.expect(historia.estado).to.eql('aprobado'));",
              "pm.test('Geografía fue recalculada como aprobada', () => pm.expect(geografia.estado).to.eql('aprobado'));",
              "pm.test('Todos los espacios de Historia están aprobados', () => {",
              "    pm.expect(historia.espacios_curriculares.every(item => item.estado === 'aprobado')).to.eql(true);",
              "});",
              "pm.test('Todos los espacios de Geografía están aprobados', () => {",
              "    pm.expect(geografia.espacios_curriculares.every(item => item.estado === 'aprobado')).to.eql(true);",
              "});",
              "",
              "pm.collectionVariables.unset('runId');",
              "pm.collectionVariables.unset('dni');"
            ]
          }
        }
      ]
