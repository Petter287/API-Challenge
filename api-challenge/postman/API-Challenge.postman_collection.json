      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.info.requestName === '01 - Crear estudiante' || !pm.collectionVariables.get('runId')) {",
          "    const timestamp = Date.now();",
          "    pm.collectionVariables.set('runId', String(timestamp));",
          "    pm.collectionVariables.set('dni', String(10000000 + (timestamp % 90000000)));",
          "}"
        ]
      }
    }
