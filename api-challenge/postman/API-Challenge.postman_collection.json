    {
      "name": "12 - Caso 2 y 4: materias en proceso y espacio compartido",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students/{{studentId}}/subjects-status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "students",
            "{{studentId}}",
            "subjects-status"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Consulta exitosa - HTTP 200', () => pm.response.to.have.status(200));",
              "const materias = pm.response.json();",
              "const runId = pm.collectionVariables.get('runId');",
              "const historia = materias.find(item => item.materia.includes(`Historia ${runId}`));",
              "const geografia = materias.find(item => item.materia.includes(`Geografía ${runId}`));",
              "",
              "pm.test('Historia aparece en el resultado', () => pm.expect(historia).to.exist);",
              "pm.test('Geografía aparece en el resultado', () => pm.expect(geografia).to.exist);",
              "pm.test('Historia está en_proceso', () => pm.expect(historia.estado).to.eql('en_proceso'));",
              "pm.test('Geografía está en_proceso', () => pm.expect(geografia.estado).to.eql('en_proceso'));",
              "pm.test('Historia conserva la trazabilidad de dos espacios', () => pm.expect(historia.espacios_curriculares).to.have.length(2));",
              "pm.test('Geografía conserva la trazabilidad de dos espacios', () => pm.expect(geografia.espacios_curriculares).to.have.length(2));",
              "pm.test('El espacio compartido impacta en ambas materias', () => {",
              "    const nombre = `Laboratorio de Ciencias Sociales I ${runId}`;",
              "    pm.expect(historia.espacios_curriculares.some(item => item.nombre === nombre)).to.eql(true);",
              "    pm.expect(geografia.espacios_curriculares.some(item => item.nombre === nombre)).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
