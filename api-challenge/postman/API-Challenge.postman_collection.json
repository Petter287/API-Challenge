      "name": "01 - Crear estudiante",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Prueba {{runId}}\",\n  \"dni\": \"{{dni}}\",\n  \"fechaNacimiento\": \"2000-05-10\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/students",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "students"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Estudiante creado - HTTP 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.test('La respuesta indica éxito', () => pm.expect(json.success).to.eql(true));",
              "pm.test('Devuelve el ID del estudiante', () => pm.expect(json.data.id).to.exist);",
              "pm.collectionVariables.set('studentId', json.data.id);"
            ]
          }
        }
